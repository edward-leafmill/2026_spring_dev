{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "configure (cmake UCRT64)",
            "type": "shell",
            "command": "C:\\msys64\\ucrt64\\bin\\cmake.exe",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${command:cmake.buildDirectory}",
                "-G",
                "MinGW Makefiles",
                "-DCMAKE_BUILD_TYPE=Debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake: build all",
            "type": "shell",
            "command": "C:\\msys64\\ucrt64\\bin\\cmake.exe",
            "args": [
                "--build",
                "${command:cmake.buildDirectory}",
                "--target",
                "course_all_labs"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "configure (cmake UCRT64)",
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "CMake: build launch target",
            "type": "shell",
            "command": "C:\\msys64\\ucrt64\\bin\\cmake.exe",
            "args": [
                "--build",
                "${command:cmake.buildDirectory}",
                "--target",
                "${command:cmake.launchTargetName}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "configure (cmake UCRT64)",
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "CMake: build q01",
            "type": "shell",
            "command": "C:\\msys64\\ucrt64\\bin\\cmake.exe",
            "args": [
                "--build",
                "${command:cmake.buildDirectory}",
                "--target",
                "lab_q01"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "configure (cmake UCRT64)",
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}
